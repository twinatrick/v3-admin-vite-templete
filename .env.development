  # user define variable (must named VITE_...)

## backend api url (if is cross-domain, must be set full url)
VITE_BASE_API='/api/v1'

## swagger/openapi url for API generation
VITE_SWAGGER_URL='http://localhost:8000/v3/api-docs-merged'

## router history: hash or html5
VITE_ROUTER_HISTORY='hash'

## development url(normally '/' or './')
VITE_PUBLIC_PATH='/'

## your app id
VITE_GOOGLE_APP_ID=''
## your google client id
VITE_GOOGLE_CLIENT_ID=''
## ypur google api key
VITE_GOOGLE_API_KEY=''

{
  "name": "frontend",
  "version": "4.0.0",
  "description": "nothing to say",
  "scripts": {
    "dev": "vite",
    "build:dev": "vue-tsc --noEmit && vite build --mode development",
    "build:stage": "vue-tsc --noEmit && vite build --mode staging",
    "build:prod": "vue-tsc --noEmit && vite build",
    "preview:stage": "pnpm build:stage && vite preview",
    "preview:prod": "pnpm build:prod && vite preview",
    "lint:eslint": "eslint --cache --max-warnings 0 \"{src,tests,types}/**/*.{vue,js,jsx,ts,tsx}\" --fix",
    "lint:prettier": "prettier --write \"{src,tests,types}/**/*.{vue,js,jsx,ts,tsx,json,css,less,scss,html,md}\"",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "precommit": "pnpm lint && pnpm lint-staged",
    "prepare": "husky install || true",
    "test": "vitest",
    "generate-api": "node scripts/generate-api.js",
    "generate-api:dev": "node scripts/generate-api.js --env development",
    "generate-api:prod": "node scripts/generate-api.js --env production"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-build-classic": "^40.2.0",
    "@ckeditor/ckeditor5-vue": "^5.1.0",
    "@element-plus/icons-vue": "2.1.0",
    "@infectoone/vue-ganttastic": "^2.2.0",
    "@popperjs/core": "^2.11.8",
    "apexcharts": "^5.10.0",
    "axios": "1.6.0",
    "dayjs": "1.11.8",
    "element-plus": "2.7.2",
    "js-cookie": "3.0.5",
    "lodash": "^4.17.21",
    "lodash-es": "4.17.21",
    "normalize.css": "8.0.1",
    "nprogress": "0.2.0",
    "path-browserify": "1.0.1",
    "path-to-regexp": "6.2.1",
    "pinia": "^2.1.0",
    "screenfull": "6.0.2",
    "sortablejs": "^1.15.0",
    "v-calendar": "^3.1.2",
    "vue": "^3.5.13",
    "vue-router": "4.2.2",
    "vue3-apexcharts": "^1.5.3",
    "vuedraggable": "^4.1.0",
    "vxe-table": "4.4.1",
    "vxe-table-plugin-element": "3.0.7",
    "xe-utils": "3.5.11"
  },
  "devDependencies": {
    "@types/js-cookie": "3.0.3",
    "@types/lodash": "^4.17.1",
    "@types/lodash-es": "4.17.7",
    "@types/node": "20.3.2",
    "@types/nprogress": "0.2.0",
    "@types/path-browserify": "1.0.0",
    "@types/sortablejs": "^1.15.3",
    "@typescript-eslint/eslint-plugin": "5.60.1",
    "@typescript-eslint/parser": "5.60.1",
    "@vitejs/plugin-vue": "4.2.3",
    "@vitejs/plugin-vue-jsx": "3.0.1",
    "@vitest/coverage-v8": "^0.32.2",
    "@vue/eslint-config-prettier": "7.1.0",
    "@vue/eslint-config-typescript": "11.0.3",
    "@vue/test-utils": "2.4.0",
    "cypress": "^13.6.6",
    "cypress-log-to-output": "^1.1.2",
    "cypress-vite": "^1.8.0",
    "dotenv": "^17.4.2",
    "eslint": "8.43.0",
    "eslint-plugin-prettier": "4.2.1",
    "eslint-plugin-vue": "9.15.1",
    "husky": "8.0.3",
    "jsdom": "22.1.0",
    "lint-staged": "13.2.2",
    "prettier": "2.8.8",
    "sass": "1.63.6",
    "swagger-typescript-api": "^13.6.5",
    "terser": "5.18.1",
    "typescript": "5.1.3",
    "unocss": "0.53.4",
    "vite": "4.3.9",
    "vite-plugin-svg-icons": "2.0.1",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vite-svg-loader": "4.0.0",
    "vitest": "0.32.2",
    "vue-eslint-parser": "9.3.1",
    "vue-tsc": "1.8.2"
  },
  "lint-staged": {
    "*.{vue,js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,less,scss,html,md}": [
      "prettier --write"
    ],
    "package.json": [
      "prettier --write"
    ]
  },
  "keywords": [
    "vue",
    "vue3",
    "admin",
    "vue-admin",
    "vue3-admin",
    "vite",
    "vite-admin",
    "element-plus",
    "element-plus-admin",
    "ts",
    "typescript"
  ],
  "license": "MIT",
  "web-types": "./web-types.json"
}
